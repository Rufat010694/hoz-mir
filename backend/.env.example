# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hozmir
DATABASE_SYNC_URL=postgresql+psycopg://user:password@localhost:5432/hozmir

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379

# Backblaze B2
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET_NAME=hozmir-photos
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
APP_NAME=Хоз Мир
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
