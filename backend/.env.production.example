# Скопируй в .env и заполни реальными значениями

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/hozmir
DATABASE_SYNC_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/hozmir

SECRET_KEY=сгенерируй-длинный-случайный-ключ-здесь
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

REDIS_URL=redis://localhost:6379

B2_KEY_ID=твой-key-id
B2_APP_KEY=твой-app-key
B2_BUCKET_NAME=hozmir-photos
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Домен фронтенда — Railway или Vercel URL
CORS_ORIGINS=["https://твой-домен.vercel.app","https://твой-railway-домен.railway.app"]

DEBUG=False
